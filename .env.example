# ============================================================
# Leap One 项目管理系统 - 环境变量配置模板
# ============================================================
# 使用说明：
#   1. 复制此文件为 .env: cp .env.example .env
#   2. 根据实际环境修改配置值
#   3. 生产环境请务必修改所有密码和密钥
#   4. .env 文件已添加到 .gitignore，不会被提交到版本库
# ============================================================

# ----------------------------------------------------------
# 数据库密码（生产环境请使用强随机密码）
# ----------------------------------------------------------
DB_PASSWORD=LeapOne@2026Secure

# ----------------------------------------------------------
# Redis 密码（生产环境请使用强随机密码）
# ----------------------------------------------------------
REDIS_PASSWORD=LeapOne@Redis2026

# ----------------------------------------------------------
# JWT 密钥（生产环境请使用强随机字符串，至少32位）
# 生成方式: openssl rand -base64 32
# ----------------------------------------------------------
JWT_SECRET=LeapOne-JWT-Secret-Key-2026-Secure-Random-String

# ----------------------------------------------------------
# 通用应用配置
# ----------------------------------------------------------
APP_ENV=development
LOG_LEVEL=debug
GIN_MODE=debug

# ----------------------------------------------------------
# API 网关配置
# ----------------------------------------------------------
GATEWAY_PORT=8080

# ----------------------------------------------------------
# Nginx 配置
# ----------------------------------------------------------
NGINX_PORT=80
NGINX_SSL_PORT=443

# ----------------------------------------------------------
# AI 服务配置（可选）
# ----------------------------------------------------------
# AI_API_KEY=your-ai-api-key
# AI_MODEL=gpt-4
# AI_BASE_URL=https://api.openai.com/v1

# ----------------------------------------------------------
# 邮件服务配置（可选）
# ----------------------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=Leap One <noreply@example.com>

# ----------------------------------------------------------
# 对象存储配置（可选，用于文档/附件存储）
# ----------------------------------------------------------
# STORAGE_TYPE=local
# STORAGE_ENDPOINT=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_BUCKET=leapone-uploads

# ----------------------------------------------------------
# Sentry 错误追踪（可选）
# ----------------------------------------------------------
# SENTRY_DSN=

# ----------------------------------------------------------
# Prometheus 监控（可选）
# ----------------------------------------------------------
# METRICS_ENABLED=true
# METRICS_PORT=9090
